configuration {
    modi: "drun,run,window";
    show-icons: true;
    drun-display-format: "{name}";
    display-drun: "  Apps";
    display-run: "  Run";
    display-window: "  Windows";
    font: "JetBrainsMono Nerd Font 13";
    icon-theme: "Papirus";
    terminal: "kitty";
}

@theme "~/.config/rofi/theme.rasi"
